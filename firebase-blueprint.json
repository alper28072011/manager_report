{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role-based access control.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["super_admin", "user"] },
        "allowed_hotels": { "type": "array", "items": { "type": "string" }, "description": "Array of hotel_codes the user can access" },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["uid", "email", "role"]
    },
    "Hotel": {
      "title": "Hotel",
      "description": "Hotel configuration including API keys.",
      "type": "object",
      "properties": {
        "hotel_code": { "type": "string" },
        "name": { "type": "string" },
        "api_key": { "type": "string" },
        "is_active": { "type": "boolean" },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["hotel_code", "name", "api_key", "is_active"]
    },
    "QueryTemplate": {
      "title": "QueryTemplate",
      "description": "Global query templates used across all hotels.",
      "type": "object",
      "properties": {
        "query_name": { "type": "string" },
        "api_url": { "type": "string" },
        "api_object": { "type": "string" },
        "payload_template": { "type": "string" },
        "response_index": { "type": "number" },
        "is_active": { "type": "boolean" },
        "createdAt": { "type": "timestamp" },
        "updatedAt": { "type": "timestamp" }
      },
      "required": ["query_name", "api_url", "api_object", "payload_template", "response_index", "is_active"]
    },
    "ReportView": {
      "title": "ReportView",
      "description": "Saved report parameters and column visibility preferences.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "hotel_code": { "type": "string" },
        "parameters": { "type": "object" },
        "visible_columns": { "type": "object" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "hotel_code", "parameters", "visible_columns"]
    },
    "HotelParameter": {
      "title": "HotelParameter",
      "description": "Static parameters for a hotel (e.g. ROOM_CAPACITY)",
      "type": "object",
      "properties": {
        "hotel_id": { "type": "string" },
        "param_key": { "type": "string" },
        "param_value": { "type": "string" },
        "param_type": { "type": "string", "enum": ["number", "date", "text"] },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["hotel_id", "param_key", "param_value", "param_type"]
    },
    "CalculatedMeasure": {
      "title": "CalculatedMeasure",
      "description": "User defined formulas for calculated metrics",
      "type": "object",
      "properties": {
        "hotel_id": { "type": "string" },
        "measure_name": { "type": "string" },
        "formula": { "type": "string" },
        "format_type": { "type": "string", "enum": ["number", "percentage", "currency"] },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["hotel_id", "measure_name", "formula", "format_type"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/hotels/{hotelId}": {
      "schema": { "$ref": "#/entities/Hotel" },
      "description": "Hotel configurations"
    },
    "/queries/{queryId}": {
      "schema": { "$ref": "#/entities/QueryTemplate" },
      "description": "Global query templates"
    },
    "/report_views/{viewId}": {
      "schema": { "$ref": "#/entities/ReportView" },
      "description": "Stores saved report views."
    },
    "/hotel_parameters/{paramId}": {
      "schema": { "$ref": "#/entities/HotelParameter" },
      "description": "Hotel parameters"
    },
    "/calculated_measures/{measureId}": {
      "schema": { "$ref": "#/entities/CalculatedMeasure" },
      "description": "Calculated measures"
    }
  }
}
